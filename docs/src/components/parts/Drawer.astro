---
import { themeConfig } from '../theme-config';
import { getTranslation } from './NavBar.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
const { sidebar } = Astro.locals.starlightRoute;

const currentPath = Astro.url.pathname;
---

<div popover="auto" id="drawer">
    <button class="sheet-overlay" popovertarget="drawer" popovertargetaction="hide"></button>
    <div class="content">
        <div class="header">
            <button class="drag-icon" popovertarget="drawer" popovertargetaction="hide">
                <span></span>
            </button>
        </div>
        <div class="body">
            <div class="links-nav">
                {
                    themeConfig.navLinks?.map((nav) => {
                        const absoluteLinkRegex = /^https?:\/\//;

                        const link =
                            !absoluteLinkRegex.test(nav.link) && Astro.currentLocale
                                ? getRelativeLocaleUrl(Astro.currentLocale, nav.link)
                                : nav.link;
                        const label =
                            typeof nav.label === 'string'
                                ? nav.label
                                : getTranslation(nav.label, nav.link, 'label');

                        return (
                            <a href={link} {...nav.attrs}>
                                {label}
                                {nav.badge && <span class="badge">{nav.badge}</span>}
                            </a>
                        );
                    })
                }
            </div>

            <div class="links-docs">
                {
                    sidebar.map(
                        (entry) =>
                            entry.type !== 'link' && (
                                <div class="container-sidebar-entry">
                                    <h4 class="entry-title">{entry.label}</h4>

                                    {entry.entries.map(
                                        (link) =>
                                            link.type === 'link' && (
                                                <a
                                                    href={link.href}
                                                    {...link.attrs}
                                                    data-active={currentPath === link.href}
                                                >
                                                    {link.label}
                                                </a>
                                            )
                                    )}
                                </div>
                            )
                    )
                }
            </div>
        </div>
    </div>
</div>

<style>
    button {
        all: unset;
    }

    [popover] {
        padding: 0;
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        display: flex;
        opacity: 0;
        pointer-events: none;
        align-items: center;
        flex-direction: column;
        justify-content: flex-end;
        z-index: 1000;
        background: transparent;
        border: none;
        overflow: hidden;
    }

    [popover]::backdrop {
        background: color-mix(in oklab, black 80%, transparent);
        backdrop-filter: blur(2px);
    }

    [popover]:popover-open {
        opacity: 1;
        pointer-events: auto;
    }

    [popover]:popover-open .content {
        transform: translateY(0%);
    }

    .sheet-overlay {
        position: fixed;
        top: 0;
        left: 0;
        z-index: -1;
        width: 100vw;
        height: 100vh;
        opacity: 0.1;
        background-color: transparent;
    }

    .content {
        width: 100%;
        position: relative;
        background: var(--background);
        max-height: 100vh;
        height: 70vh;
        max-width: 1150px;
        transform: translateY(100%);
        border-radius: 12px 12px 0 0;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.03);
    }

    .header {
        display: flex;
        justify-content: center;
    }

    .header .drag-icon span {
        height: calc(var(--spacing) * 1);
        width: 100px;
        display: block;
        background-color: color-mix(in oklab, var(--foreground) 20%, transparent);
        border-radius: 9999px;
        margin-top: calc(var(--spacing) * 1);
    }

    .header .drag-icon {
        border-radius: 9999px;
    }

    .body {
        height: 100%;
        overflow-y: auto;
        overscroll-behavior-y: contain;
        padding: 1.5rem;
    }

    .body::-webkit-scrollbar {
        width: 0;
    }

    .links-nav {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .links-nav a {
        font-size: 1rem;
        line-height: 1.5rem;
        color: inherit;
        text-decoration: inherit;
        border-radius: var(--radius-xs, 0.25rem);
        width: fit-content;
        max-width: 100%;
    }

    .links-docs {
        display: flex;
        flex-direction: column;
        gap: calc(var(--spacing) * 2);
    }

    .container-sidebar-entry {
        padding-top: calc(var(--spacing) * 6);
        display: flex;
        flex-direction: column;
        gap: calc(var(--spacing) * 2);

        &:last-child {
            margin-bottom: calc(var(--spacing) * 4);
        }
    }

    .entry-title {
        font-weight: 500;
    }

    .container-sidebar-entry a {
        font-size: 1rem;
        line-height: 1.2rem;
        color: var(--muted-foreground);
        text-decoration: inherit;
        border-radius: var(--radius-xs, 0.25rem);
        width: fit-content;
        max-width: 100%;

        &[data-active='true'] {
            color: var(--foreground);
            font-weight: 500;
        }
    }

    .badge {
        padding-top: calc(var(--spacing) * 0.5);
        padding-bottom: calc(var(--spacing) * 0.5);
        padding-left: calc(var(--spacing) * 1.5);
        padding-right: calc(var(--spacing) * 1.5);
        margin-left: calc(var(--spacing) * 2);
        border-radius: 0.375rem;
        font-size: 0.75rem;
        line-height: 1rem;
        font-weight: 400;
        line-height: 1;
        text-decoration: none;
        background: #adfa1d;
        color: #000000;
    }
</style>

<script>
    const drawer = document.getElementById('drawer');
    if (drawer) {
        drawer.addEventListener('toggle', (e) => {
            const event = e as ToggleEvent;
            const isOpen = event.newState === 'open';
            document.documentElement.style.overflow = isOpen ? 'hidden' : '';
            document.body.style.overflow = isOpen ? 'hidden' : '';
        });
    }
</script>
