---
import TableOfContents from './TableOfContents.astro';
---

{
    Astro.locals.starlightRoute.toc && (
        <div>
            <TableOfContents />
        </div>
    )
}

<style>
    div {
        --toc-sticky-top: calc(var(--header-height) + var(--docs-content-top-offset, 0px));
        --toc-sticky-bottom: var(--docs-content-top-offset, 0px);
        --toc-edge-gap: calc(var(--spacing) * 4);

        box-sizing: border-box;
        padding-block: var(--toc-edge-gap);
        height: calc(100svh - var(--toc-sticky-top) - var(--toc-sticky-bottom));
        max-height: calc(100svh - var(--toc-sticky-top) - var(--toc-sticky-bottom));
        min-height: 0;
        overflow: hidden;
        top: var(--toc-sticky-top);
        position: sticky;
    }
</style>
