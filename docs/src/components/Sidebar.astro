---
import SidebarSublist from './parts/SidebarSublist.astro';

const { sidebar } = Astro.locals.starlightRoute;
---

<script is:inline>
    (() => {
        const sidebarGroupStateKey = 'lucent:sidebar-groups:v2';

        const readSidebarGroupState = () => {
            try {
                const stored = sessionStorage.getItem(sidebarGroupStateKey);
                const parsed = stored ? JSON.parse(stored) : {};

                return parsed && typeof parsed === 'object' && !Array.isArray(parsed) ? parsed : {};
            } catch {
                return {};
            }
        };

        window.__lucentSidebarGroupState = readSidebarGroupState();
    })();
</script>

<div class="sidebar">
    <div class="sidebar-border-gradient"></div>
    <div class="sidebar-spacer"></div>
    <div class="sidebar-fade-top"></div>
    <div class="container-sidebar">
        <div class="sidebar-entries">
            <SidebarSublist sublist={sidebar} />
        </div>
        <div class="sidebar-fade-bottom"></div>
    </div>
</div>

<script is:inline>
    (() => {
        const sidebarGroupStateKey = 'lucent:sidebar-groups:v2';
        const sidebarScrollStateKey = 'lucent:sidebar-scroll-top';

        const readSidebarGroupState = () => {
            try {
                const stored = sessionStorage.getItem(sidebarGroupStateKey);
                const parsed = stored ? JSON.parse(stored) : {};

                return parsed && typeof parsed === 'object' && !Array.isArray(parsed) ? parsed : {};
            } catch {
                return {};
            }
        };

        const writeSidebarGroupState = (state) => {
            try {
                sessionStorage.setItem(sidebarGroupStateKey, JSON.stringify(state));
            } catch {
                // Browsers can disable storage. The default server-rendered state still works.
            }
        };

        const readSidebarScrollTop = () => {
            try {
                const stored = sessionStorage.getItem(sidebarScrollStateKey);
                if (stored === null) return null;

                const value = Number.parseInt(stored, 10);
                return Number.isFinite(value) && value >= 0 ? value : null;
            } catch {
                return null;
            }
        };

        const writeSidebarScrollTop = (scrollTop) => {
            try {
                sessionStorage.setItem(
                    sidebarScrollStateKey,
                    String(Math.max(0, Math.round(scrollTop)))
                );
            } catch {
                // Browsers can disable storage. Losing scroll restoration is non-critical.
            }
        };

        const getSidebarScroller = () => document.querySelector('.container-sidebar');

        const saveSidebarScrollTop = () => {
            const scroller = getSidebarScroller();
            if (!(scroller instanceof HTMLElement)) return;

            writeSidebarScrollTop(scroller.scrollTop);
        };

        const restoreSidebarScrollTop = () => {
            const scroller = getSidebarScroller();
            const storedScrollTop = readSidebarScrollTop();

            if (!(scroller instanceof HTMLElement) || storedScrollTop === null) return;

            const restore = () => {
                const maxScrollTop = Math.max(0, scroller.scrollHeight - scroller.clientHeight);
                scroller.scrollTop = Math.min(storedScrollTop, maxScrollTop);
            };

            restore();
            requestAnimationFrame(restore);
            requestAnimationFrame(() => requestAnimationFrame(restore));
        };

        const bindSidebarGroupState = () => {
            const storedState = window.__lucentSidebarGroupState ?? readSidebarGroupState();

            for (const details of document.querySelectorAll('details[data-sidebar-group]')) {
                const group = details.dataset.sidebarGroup;
                if (!group) continue;

                const storedOpen = storedState[group];
                if (typeof storedOpen === 'boolean' && details.open !== storedOpen) {
                    details.open = storedOpen;
                }

                if (details.dataset.sidebarStateBound === 'true') continue;
                details.dataset.sidebarStateBound = 'true';

                details.addEventListener('toggle', () => {
                    const nextState = readSidebarGroupState();
                    nextState[group] = details.open;
                    window.__lucentSidebarGroupState = nextState;
                    writeSidebarGroupState(nextState);
                });
            }
        };

        const bindSidebarScrollState = () => {
            const scroller = getSidebarScroller();
            if (!(scroller instanceof HTMLElement)) return;

            restoreSidebarScrollTop();

            if (scroller.dataset.sidebarScrollBound === 'true') return;
            scroller.dataset.sidebarScrollBound = 'true';

            let scrollFrame = 0;
            scroller.addEventListener(
                'scroll',
                () => {
                    if (scrollFrame !== 0) return;
                    scrollFrame = requestAnimationFrame(() => {
                        scrollFrame = 0;
                        writeSidebarScrollTop(scroller.scrollTop);
                    });
                },
                { passive: true }
            );

            scroller.addEventListener('click', (event) => {
                if (!(event.target instanceof Element)) return;
                if (event.target.closest('a[href]')) {
                    writeSidebarScrollTop(scroller.scrollTop);
                }
            });
        };

        const bindSidebarState = () => {
            bindSidebarGroupState();
            bindSidebarScrollState();
        };

        bindSidebarState();

        if (!window.__lucentSidebarGroupsBound) {
            document.addEventListener('astro:before-swap', saveSidebarScrollTop);
            document.addEventListener('astro:after-swap', bindSidebarState);
            window.addEventListener('pagehide', saveSidebarScrollTop);
            window.__lucentSidebarGroupsBound = true;
        }
    })();
</script>

<style>
    .sidebar {
        scrollbar-width: none;
        overflow: hidden;
        height: 100%;
        position: relative;
        display: flex;
        flex-direction: column;
    }

    .sidebar-spacer {
        height: 2.25rem;
        flex-shrink: 0;
    }

    .sidebar-border-gradient {
        position: absolute;
        top: 0rem;
        right: 0.5rem;
        bottom: 0;
        width: 1px;
        background: linear-gradient(to bottom, transparent 0%, var(--border) 50%, transparent 100%);
        display: none;
        z-index: 1;
    }

    @media (min-width: 1024px) {
        .sidebar-border-gradient {
            display: flex;
        }
    }

    .sidebar-fade-top {
        position: absolute;
        top: 2rem;
        left: 0;
        z-index: 10;
        height: 2rem;
        width: calc(100% - 1rem);
        flex-shrink: 0;
        pointer-events: none;
        background-image: linear-gradient(
            to bottom,
            var(--background) 0%,
            color-mix(in srgb, var(--background) 80%, transparent) 50%,
            color-mix(in srgb, var(--background) 50%, transparent) 100%
        );
        filter: blur(2px);
    }

    .sidebar-fade-bottom {
        position: sticky;
        bottom: -2px;
        z-index: 10;
        height: 4rem;
        flex-shrink: 0;
        margin-top: calc(var(--spacing) * -16);
        pointer-events: none;
        background-image: linear-gradient(
            to top,
            var(--background) 0%,
            color-mix(in srgb, var(--background) 80%, transparent) 50%,
            color-mix(in srgb, var(--background) 50%, transparent) 100%
        );
        filter: blur(2px);
    }

    .container-sidebar {
        flex-direction: column;
        display: flex;
        overflow-x: hidden;
        overflow-y: auto;
        overscroll-behavior-y: contain;
        scrollbar-width: none;
        flex: 1;
        min-height: 0;
        min-width: 0;
        padding-top: calc(var(--spacing) * 6);
        padding-right: calc(var(--spacing) * 6);
        padding-left: calc(var(--spacing) * 2);
        margin: 0 2rem;
    }

    .sidebar-entries {
        display: flex;
        flex-direction: column;
        gap: calc(var(--spacing) * 6);
        min-width: 0;
        padding-bottom: calc(var(--spacing) * 16);
    }

    @media (min-width: 1024px) {
        .container-sidebar {
            max-height: calc(100svh - 10rem - 2.25rem);
        }
    }
</style>
