{
  "name": "@lucent/electron",
  "productName": "Lucent",
  "version": "0.0.1",
  "main": "dist/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/toommyliu/lucent.git"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile": "node esbuild.config.js",
    "compile:watch": "node esbuild.config.js --watch",
    "compile:prod": "cross-env NODE_ENV=production node esbuild.config.js",
    "electron": "node scripts/start-electron.mjs",
    "build": "pnpm run compile:prod",
    "build:fast": "pnpm run compile:prod && pnpm run electron-builder build",
    "electron-builder": "electron-builder"
  },
  "dependencies": {
    "@lucent/collection": "workspace:*",
    "@lucent/game": "workspace:*",
    "@lucent/shared": "workspace:*",
    "@lucent/ui": "workspace:*",
    "@tanstack/solid-hotkeys": "^0.10.0",
    "@tanstack/solid-virtual": "3.13.24",
    "abort-controller": "^3.0.0",
    "core-js": "^3.49.0",
    "effect": "4.0.0-beta.43",
    "solid-js": "^1.9.12",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@tanstack/solid-devtools": "^0.8.2",
    "@tanstack/solid-hotkeys-devtools": "^0.7.0",
    "cross-env": "^10.0.0",
    "electron": "workspace:*",
    "electron-builder": "^26.15.0",
    "esbuild": "^0.25.5",
    "esbuild-plugin-solid": "^0.6.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  }
}
