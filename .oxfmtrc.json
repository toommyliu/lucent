{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "node_modules",
    ".git",
    "dist",
    "build",
    "scripts",
    "**/*.css",
    "**/*.html",
    "**/*.json",
    "**/*.jsonc",
    "**/*.md",
    "**/*.toml",
    "**/*.yaml",
    "**/*.yml",
    "**/*.ts",
    "**/*.tsx",
    "*.tsbuildinfo"
  ],
  "printWidth": 80,
  "sortPackageJson": false
}
