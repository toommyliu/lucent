{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "node_modules",
    ".git",
    ".repos",
    "dist",
    "build",
    "scripts",
    "docs/.astro",
    "docs/public/script-api.d.ts",
    "docs/src/generated",
    "**/*.css",
    "**/*.html",
    "**/*.json",
    "**/*.jsonc",
    "**/*.md",
    "**/*.toml",
    "**/*.yaml",
    "**/*.yml",
    "*.tsbuildinfo"
  ],
  "printWidth": 80,
  "sortPackageJson": false
}
