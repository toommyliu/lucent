{
  "name": "@lucent/shared",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsdown --format cjs --dts --outDir dist \"src/*.ts\"",
    "postinstall": "npm run build"
  },
  "devDependencies": {
    "tsdown": "0.22.3",
    "typescript": "^5.9.3"
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.cts",
      "default": "./dist/*.cjs"
    },
    "./package.json": "./package.json"
  }
}
